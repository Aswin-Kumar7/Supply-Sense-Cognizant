# SupplySense Environment Configuration — Example
# Copy this file to .env and fill in your values.
# Docker is not used. Run with start_backend.sh / start_frontend.sh.

# ── PostgreSQL (local) ─────────────────────────────────────────────────────
POSTGRES_USER=supplysense
POSTGRES_PASSWORD=changeme
POSTGRES_DB=supplysense
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://supplysense:changeme@localhost:5432/supplysense

# ── AWS Bedrock ────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_MAX_TOKENS=2048
BEDROCK_TEMPERATURE=0.3

# Guardrails — optional. Set to your Bedrock Guardrail ID to block:
#   - hallucinated supplier names not in the database
#   - rupee figures that don't match engine outputs
#   - false certainty claims when signal confidence is low
# Leave blank to disable guardrails.
BEDROCK_GUARDRAIL_ID=
BEDROCK_GUARDRAIL_VERSION=DRAFT

# ── Backend ────────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Frontend ───────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_SSE_URL=http://localhost:8000/api/v1/events/stream

# ── App ────────────────────────────────────────────────────────────────────
APP_NAME=SupplySense
APP_VERSION=0.5.0
ENVIRONMENT=development

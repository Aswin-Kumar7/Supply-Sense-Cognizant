# ── SupplySense Backend — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your values.
# The backend reads .env automatically via pydantic-settings.

# Database (required — no default to prevent accidental production connections)
DATABASE_URL=postgresql+asyncpg://postgres:supplysense123@localhost:5432/supplysense

# AWS credentials for Bedrock + Strands Agents SDK
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1

# Bedrock model (Claude 3 Haiku — cheapest, fastest; ~$0.00025/1K tokens)
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_MAX_TOKENS=2048
BEDROCK_TEMPERATURE=0.3

# Bedrock Guardrail (optional — leave blank to skip guardrail validation)
BEDROCK_GUARDRAIL_ID=
BEDROCK_GUARDRAIL_VERSION=DRAFT

# Application
ENVIRONMENT=development
LOG_LEVEL=INFO
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
